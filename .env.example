# =============================================================================
# Distill — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------

# Neon Postgres connection string
# Get from: https://console.neon.tech → your project → Connection Details
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/distill?sslmode=require

# -----------------------------------------------------------------------------
# Authentication (required)
# -----------------------------------------------------------------------------

# Password for the Distill dashboard login
AUTH_PASSWORD=your-password-here

# Bearer token for authorizing cron job requests
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------

# LLM provider to use: "anthropic" (default), "openai", or "ollama"
LLM_PROVIDER=anthropic

# --- Anthropic (required if LLM_PROVIDER=anthropic) ---

# Anthropic API key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Model for structuring (fast, cheaper)
# Default: claude-haiku-4-5-20251001
# ANTHROPIC_STRUCTURE_MODEL=claude-haiku-4-5-20251001

# Model for synthesis (higher quality)
# Default: claude-sonnet-4-6
# ANTHROPIC_SYNTHESIZE_MODEL=claude-sonnet-4-6

# --- OpenAI (required if LLM_PROVIDER=openai) ---

# OpenAI API key
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Model for structuring (fast, cheaper)
# Default: gpt-4o-mini
# OPENAI_STRUCTURE_MODEL=gpt-4o-mini

# Model for synthesis (higher quality)
# Default: gpt-4o
# OPENAI_SYNTHESIZE_MODEL=gpt-4o

# --- Ollama (required if LLM_PROVIDER=ollama) ---

# Ollama server base URL
# Default: http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434

# Model for structuring
# Default: llama3.2
# OLLAMA_STRUCTURE_MODEL=llama3.2

# Model for synthesis
# Default: llama3.2
# OLLAMA_SYNTHESIZE_MODEL=llama3.2

# -----------------------------------------------------------------------------
# Email — Resend (required for email intake and digest delivery)
# -----------------------------------------------------------------------------

# Resend API key
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Resend webhook signing secret for validating inbound email webhooks
# Get from: https://resend.com/webhooks → your webhook → Signing Secret
RESEND_WEBHOOK_SECRET=whsec_...

# Email address used as the "from" for digest emails
# Must be a verified domain in Resend
# Default: Distill <signals@signals.example.com>
# RESEND_FROM_ADDRESS=Distill <signals@yourdomain.com>

# Comma-separated list of email addresses to receive the weekly digest
DIGEST_RECIPIENTS=team@example.com,pm@example.com

# -----------------------------------------------------------------------------
# Storage (optional)
# -----------------------------------------------------------------------------

# Vercel Blob read/write token for storing digest archives
# Get from: Vercel dashboard → Storage → Blob → Token
# If not set, digest archival is skipped
# BLOB_READ_WRITE_TOKEN=vercel_blob_...
