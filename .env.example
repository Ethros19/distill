# =============================================================================
# Distill — Signals Synthesis & Intelligence
# Copy this file to .env and fill in your values
# =============================================================================

# ---------- LLM Provider ----------
# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (alternative — set LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Provider selection: "anthropic" (default) | "openai" | "ollama"
LLM_PROVIDER=anthropic

# Model overrides (optional — sensible defaults used if omitted)
# LLM_MODEL_STRUCTURING=claude-haiku-4-5-20251001
# LLM_MODEL_SYNTHESIS=claude-sonnet-4-6-20250514

# ---------- Authentication ----------
# Password for dashboard access
SIGNAL_PASSWORD=change-me-to-something-secure

# ---------- Email Digest ----------
# Comma-separated list of email addresses to receive the weekly digest
DIGEST_RECIPIENTS=you@example.com

# ---------- Cron Schedule ----------
# Daily catch-all (default: 6 AM UTC)
# CRON_DAILY=0 6 * * *

# Weekly synthesis (default: Monday 6 AM UTC)
# CRON_WEEKLY=0 6 * * 1
